# JustInTime — local secrets template
#
# Copy this file to .env (gitignored) and fill in your values.
# The Makefile auto-loads .env before invoking `uv run jit-update`,
# so any `make data*` target will see these variables.
#
# Battle.net OAuth (client_credentials flow) — register at:
#   https://develop.battle.net/access/clients
BLIZZARD_CLIENT_ID=
BLIZZARD_CLIENT_SECRET=
